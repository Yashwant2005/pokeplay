# ── Telegram Bot Tokens ──────────────────────────────────────────────────────
# Main bot token (from @BotFather)
BOT_TOKEN=your_main_bot_token_here

# Transfer/backup bot token (from @BotFather)
TRANSFER_BOT_TOKEN=your_transfer_bot_token_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=pokeplay2

# Connection pool (optional, defaults shown)
MONGO_POOL_MAX=50
MONGO_POOL_MIN=5

# ── Session ───────────────────────────────────────────────────────────────────
# How many days before inactive sessions are deleted (default: 30)
SESSION_TTL_DAYS=30

# ── Misc ──────────────────────────────────────────────────────────────────────
# Set to 1 to suppress console.log output
QUIET_LOGS=0

# Set to 1 to enable battle debug logging
BATTLE_DEBUG=0

# Backup settings (transfer_bot.js)
BACKUP_ENABLED=false
BACKUP_CHAT_ID=
BACKUP_INTERVAL_MS=3600000
BACKUP_RUN_ON_START=true
